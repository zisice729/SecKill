<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.seckill.repository.mapper.SeckillMqFailMapper">

    <resultMap id="BaseResultMap" type="com.example.seckill.repository.entity.SeckillMqFail">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="order_id" property="orderId" jdbcType="VARCHAR"/>
        <result column="message_body" property="messageBody" jdbcType="LONGVARCHAR"/>
        <result column="error_stack" property="errorStack" jdbcType="LONGVARCHAR"/>
        <result column="create_time" property="createTime" jdbcType="TIMESTAMP"/>
        <result column="retry_count" property="retryCount" jdbcType="INTEGER"/>
        <result column="status" property="status" jdbcType="INTEGER"/>
        <result column="update_time" property="updateTime" jdbcType="TIMESTAMP"/>
    </resultMap>

    <insert id="insert" parameterType="com.example.seckill.repository.entity.SeckillMqFail">
        INSERT INTO seckill_mq_fail (order_id, message_body, error_stack, create_time, retry_count, status, update_time)
        VALUES (#{orderId}, #{messageBody}, #{errorStack}, #{createTime}, #{retryCount}, #{status}, #{updateTime})
    </insert>

    <select id="selectByOrderId" parameterType="java.lang.String" resultMap="BaseResultMap">
        SELECT * FROM seckill_mq_fail WHERE order_id = #{orderId}
    </select>

    <select id="selectPendingRetry" resultMap="BaseResultMap">
        SELECT * FROM seckill_mq_fail
        WHERE status = 0
        AND create_time &lt; DATE_SUB(NOW(), INTERVAL #{minutes} MINUTE)
        AND retry_count &lt; 5
        ORDER BY create_time ASC
        LIMIT 100
    </select>

    <update id="updateRetryCount">
        UPDATE seckill_mq_fail SET retry_count = #{retryCount}, update_time = NOW() WHERE id = #{id}
    </update>

    <update id="updateStatus">
        UPDATE seckill_mq_fail SET status = #{status}, update_time = NOW() WHERE id = #{id}
    </update>

</mapper>