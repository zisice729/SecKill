<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.seckill.mapper.GoodsMapper">

    <resultMap id="BaseResultMap" type="com.example.seckill.entity.Goods">
        <id column="id" property="id"/>
        <result column="stock" property="stock"/>
        <result column="name" property="name"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT id, stock, name, create_time, update_time
        FROM t_goods
        WHERE id = #{id}
    </select>

    <update id="deductStock">
        UPDATE t_goods
        SET stock = stock - 1, update_time = NOW()
        WHERE id = #{id} AND stock > 0
    </update>

    <update id="restoreStock">
        UPDATE t_goods
        SET stock = stock + 1, update_time = NOW()
        WHERE id = #{id}
    </update>

</mapper>